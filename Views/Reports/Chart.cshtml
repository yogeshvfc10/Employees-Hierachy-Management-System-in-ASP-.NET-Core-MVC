</div> *@

<div class="col-4">
    <h2>@ViewData["Title"]</h2>
    <canvas id="salesChart" width="200" height="110" style="width:150px; height:100px;"></canvas>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>

        var ctx = document.getElementById('salesChart').getContext('2d');
        var data = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.ChartData));

        var labels = data.map(function (e) { return e.Project; });
        var values = data.map(function (e) { return e.TotalSales; });

        var myDoughnutChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Sales',
                    data: values,
                    backgroundColor: [
                        '#FF6384',
                        '#36A2EB',
                        '#FFCE56',
                        '#4BC0C0',
                        '#9966FF'
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'top',
                    },
                    title: {
                        display: true,
                        text: 'Sales Distribution by Project'
                    }
                }
            }
        });
    </script>
}
