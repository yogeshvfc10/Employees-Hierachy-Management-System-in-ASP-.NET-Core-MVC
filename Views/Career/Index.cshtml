                                        <i class="fas fa-file-excel"></i> Excel
                                    </a>

                                    <button type="button" id="btnExport" class="btn btn-danger" style="margin-right: 11px;">
                                        <i class="fas fa-file-pdf"></i> PDF
                                    </button>
                                </div>
                            </div>

                            <div class="container mt-3">
                                <div class="row">
                                    @foreach (var item in Model.CareerGeneralModel)
                                    {
                                        <div class="col-md-4 col-sm-6 mb-3">
                                            <div class="card">
                                                <div class="card-header">
                                                    <h5>@Html.DisplayFor(modelItem => item.Title)</h5>
                                                </div>
                                                <div class="card-body">
                                                    <p><strong>Department:</strong> @Html.DisplayFor(modelItem => item.Department)</p>
                                                    <p><strong>Location:</strong> @Html.DisplayFor(modelItem => item.Region)</p>
                                                    <p><strong>Qualification:</strong> @Html.DisplayFor(modelItem => item.Qualification)</p>
                                                    <p><strong>Experience:</strong> @Html.DisplayFor(modelItem => item.Description)</p>
                                                    <p><strong>Company Benefits:</strong> @Html.DisplayFor(modelItem => item.Benefits)</p>
                                                    <p><strong>Criteria:</strong> @Html.DisplayFor(modelItem => item.Policy)</p>
                                                    <p><strong>Application Process:</strong> @Html.DisplayFor(modelItem => item.Application)</p>
                                                    <p><strong>HR Contact:</strong> @Html.DisplayFor(modelItem => item.Contacts)</p>
                                                    <p><strong>Apply CV to Email:</strong> @Html.DisplayFor(modelItem => item.ForwardMail)</p>
                                                    <p><strong>Last Date for Submitting CV:</strong> @Html.DisplayFor(modelItem => item.Deadlines)</p>
                                                </div>
                                                <div class="card-footer">
                                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary"><i class="bi bi-pencil-square"></i> Edit</a>
                                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Delete</a>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
