<!--- PDF --->

<script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/1.8.3/jquery.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.22/pdfmake.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/0.4.1/html2canvas.min.js"></script>
<script type="text/javascript">
    $("body").on("click", "#btnExport", function () {
        html2canvas($('[id*=example1]')[0], {
            onrendered: function (canvas) {
                var data = canvas.toDataURL();
                var docDefinition = {
                    content: [{
                        image: data,
                        width: 500
                    }]
                };
                pdfMake.createPdf(docDefinition).download("Table1.pdf");
            }
        });
    });
</script>


    <!-- Filter Record-->
    <div class="modal fade" id="FilterModal" tabindex="-1" role="dialog" aria-labelledby="exampleModelLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <form asp-action="Filter" asp-controller="Career" method="post">
                    <div class="modal-header">
                        <h3 class="modal-title" id="exampleModalLabel"><b>Filter</b></h3>
                        <button type="button" class="close" data-dismiss="modal" aria-label="close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>

                    <div class="modal-body">
                        <div class="form-group">
                            <label asp-for="Careers.Title" class="control-label"></label>
                            <input asp-for="Careers.Title" class="form-control" />
                            <span asp-validation-for="Careers.Title" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Careers.Department" class="control-label"></label>
                            @Html.DropDownListFor(model => model.Careers.Department, new SelectList(Model.Departments, "Id", "DepartmentName"), "Select Department", new { @class = "form-control", id = "Department", name = "Department" })
                        </div>
                        <div class="col-sm-3">
                            @Html.ValidationMessageFor(model => model.Careers.Department, "", new { @class = "error-message" })
                        </div>

                        <div class="form-group">
                            <label asp-for="Careers.Region" class="control-label"></label>
                            @Html.DropDownListFor(model => model.Careers.Region, new SelectList(Model.Regions, "Id", "RegionName"), "Select Region", new { @class = "form-control", id = "Region", name = "Region" })
                        </div>
                        <div class="col-sm-3">
                            @Html.ValidationMessageFor(model => model.Careers.Region, "", new { @class = "error-message" })
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button asp-action="Filter" asp-controller="Career" class="btn btn-primary">Filter</button>
                        <button asp-action="ClearFilter" asp-controller="Career" class="btn btn-primary btncancel">Clear All</button>
                    </div>
                </form>
            </div>
        </div>
    </div>



