@model CareerViewModel

@{
    ViewData["Title"] = "Edit";
}

<head>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f5f5f5;
            font-family: Arial, sans-serif;
        }

        .container {
            max-width: 450px;
            background-color: #fff;
            border: 1px solid #ddd;
            margin: 20px auto;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
        }

            .header h1 {
                font-size: 24px;
                color: #333;
                margin-bottom: 10px;
            }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            font-weight: bold;
        }

        input[type="text"], input[type="date"], input[type="number"], select {
            width: 100%;
            padding: 10px;
            margin-bottom: 5px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        button[type="submit"] {
            width: 100%;
            padding: 10px;
            background-color: #4CAF50;
            color: #fff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

            button[type="submit"]:hover {
                background-color: #3e8e41;
            }
    </style>
</head>

<div class="container pt-5">
    <div class="header">
        <h1><b>Edit Interview</b></h1>
        <hr />
    </div>

    @using (Html.BeginForm("Edit", "Career", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input type="hidden" asp-for="Career.Id" />

        <div class="form-group">
            <label asp-for="Career.Title" class="control-label"></label>
            <input asp-for="Career.Title" class="form-control" />
            <span asp-validation-for="Career.Title" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Career.Department" class="control-label"></label>
            @Html.DropDownListFor(model => model.Career.Department, new SelectList(Model.Department, "Id", "DepartmentName"), "Select Department", new { @class = "form-control", id = "Department", name = "Department" })
        </div>
        <div class="col-sm-3">
            @Html.ValidationMessageFor(model => model.Career.Department, "", new { @class = "error-message" })
        </div>

        <div class="form-group">
            <label asp-for="Career.Region" class="control-label"></label>
            @Html.DropDownListFor(model => model.Career.Region, new SelectList(Model.Region, "Id", "RegionName"), "Select Region", new { @class = "form-control", id = "Region", name = "Region" })
        </div>
        <div class="col-sm-3">
            @Html.ValidationMessageFor(model => model.Career.Region, "", new { @class = "error-message" })
        </div>

        <div class="form-group">
            <label asp-for="Career.Description" class="control-label"></label>
            <input asp-for="Career.Description" class="form-control" />
            <span asp-validation-for="Career.Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Career.Qualification" class="control-label"></label>
            <input asp-for="Career.Qualification" class="form-control" />
            <span asp-validation-for="Career.Qualification" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Career.Benefits" class="control-label"></label>
            <input asp-for="Career.Benefits" class="form-control" />
            <span asp-validation-for="Career.Benefits" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Application Process</label>
            <div>
                <label class="radio-inline">
                    @Html.RadioButtonFor(model => model.Career.Application, "In-Walk") In-Walk
                </label>
                <label class="radio-inline" style="margin-left: 45px;">
                    @Html.RadioButtonFor(model => model.Career.Application, "Online Mode") Online Mode
                </label>
                <span asp-validation-for="Career.Application" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Career.Deadlines" class="control-label"></label>
            <input asp-for="Career.Deadlines" class="form-control" type="date" />
            <span asp-validation-for="Career.Deadlines" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Career.ForwardMail" class="control-label"></label>
            <input asp-for="Career.ForwardMail" class="form-control" />
            <span asp-validation-for="Career.ForwardMail" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Career.Contacts" class="control-label"></label>
            <input asp-for="Career.Contacts" class="form-control" />
            <span asp-validation-for="Career.Contacts" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Career.Policy" class="control-label"></label>
            <input asp-for="Career.Policy" class="form-control" />
            <span asp-validation-for="Career.Policy" class="text-danger"></span>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Update</button>
        </div>
    }

    <div>
        @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-link" })
    </div>
</div>
