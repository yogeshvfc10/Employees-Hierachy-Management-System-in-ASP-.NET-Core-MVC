@using DocumentFormat.OpenXml.Office.CustomUI
@model EmployeeHierachy12345.Models.AnalysisFilter

@{
    ViewData["Title"] = "Index";
}

<head>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" />
</head>

<div class="card">
    <div class="card-header">
        <h1 class="card-title" style="color:dark-black; font-weight: bold;"><b>Systematic Analysis</b></h1>
    </div>

    <div class="card-body">

        <p style="width: 1590px;">
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle-dotted"></i> TIME & MATERIAL</a>

            <button type="button" id="btnExport" class="btn btn-danger float-right margin-left:25px;" style="margin-left: 12px;">
                <i class="fas fa-file-pdf"></i> PDF
            </button>

            <a class="btn btn-success float-right margin-left:25px;" asp-action="ExportPeopleInExcel" style="margin-left:12px; float:right;">
                <i class="fas fa-file-excel"></i> Excel
            </a>
            <button type="button" class="btn btn-info float-right" data-toggle="modal" data-target="#FilterModal" align="center">
                <i class="fas fa-filter"></i> Filter
            </button>
        </p>

        <!-- Filter Record-->
        <div class="modal fade" id="FilterModal" tabindex="-1" role="dialog" aria-labelledby="exampleModelLabel">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <form asp-action="Filter" asp-controller="Analysis" method="post">
                        <div class="modal-header">
                            <h3 class="modal-title" id="exampleModalLabel"><b>Filter</b></h3>
                            <button type="button" class="close" data-dismiss="modal" aria-label="close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>

                        <div class="modal-body">
                            <div class="form-group">
                                <label asp-for="Analysis.Name" class="control-label" ></label>
                                @Html.DropDownListFor(model => model.Analysis.Name, new SelectList(Model.Employee, "Id", "Name"), "Select Employee", new { @class = "form-control", id = "EmployeeRegister" })
                                <span asp-validation-for="Analysis.Name" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Analysis.Project" class="control-label"></label>
                                @Html.DropDownListFor(model => model.Analysis.Project, new SelectList(Model.Sale, "Id", "Project"), "Select Project", new { @class = "form-control", id = "Sale" })
                                <span asp-validation-for="Analysis.Project" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label class="control-label">Status</label>
                                <div>
                                    <label class="radio-inline">
                                        @Html.RadioButtonFor(model => model.Analysis.Status, "Completed") Completed
                                    </label>
                                    <label class="radio-inline" style="margin-left: 25px;">
                                        @Html.RadioButtonFor(model => model.Analysis.Status, "In Progress") In Progress
                                    </label>
                                    <span>@Html.ValidationMessageFor(model => model.Analysis.Status, "", new { @class = "text-danger" })</span>
                                </div>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button asp-action="Filter" asp-controller="Analysis" class="btn btn-primary">Filter</button>
                            <button asp-action="ClearFilter" asp-controller="Analysis" class="btn btn-primary btncancel">Clear All</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>


        <!--Table-->

        <table id="example1" class="table table-bordered table-striped">
            <thead class="thead-dark">
                <tr>
                   
                    <th>
                        @Html.DisplayNameFor(model => model.Name)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Project)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Task)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Module)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Priority)
                    </th>
                    
                    <th>
                        @Html.DisplayNameFor(model => model.Date)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.WorkingHrs)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ClientApproval)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Update)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.AuditLogs)
                    </th>
                    
                    <th>
                        @Html.DisplayNameFor(model => model.Feedback)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Status)
                    </th>

                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.AnalysisGeneralModel)
                {
                    <tr>

                        <td>
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Project)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Task)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Module)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Priority)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Date)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.WorkingHrs)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ClientApproval)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Update)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.AuditLogs)
                        </td>
                        

                        <td>
                            @Html.DisplayFor(modelItem => item.Feedback)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Status)
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil-square"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id"><i class="fas fa-trash-alt" style="color: red;"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!--- PDF --->

<script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/1.8.3/jquery.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.22/pdfmake.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/0.4.1/html2canvas.min.js"></script>
<script type="text/javascript">
    $("body").on("click", "#btnExport", function () {
        html2canvas($('[id*=example1]')[0], {
            onrendered: function (canvas) {
                var data = canvas.toDataURL();
                var docDefinition = {
                    content: [{
                        image: data,
                        width: 500
                    }]
                };
                pdfMake.createPdf(docDefinition).download("Table1.pdf");
            }
        });
    });
</script>



