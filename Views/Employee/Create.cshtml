@model ViewModel

@{
    ViewData["Title"] = "Home Page";
}


<head>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" />


<style>
    .switch {
        position: relative;
        display: inline-block;
        width: 30px; /* reduced width */
        height: 18px; /* reduced height */
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        -webkit-transition: .4s;
        transition: .4s;
        border-radius: 18px; /* added border radius for rounded corners */
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 14px; /* reduced height */
            width: 14px; /* reduced width */
            left: 2px;
            bottom: 2px;
            background-color: white;
            -webkit-transition: .4s;
            transition: .4s;
            border-radius: 50%; /* added border radius for rounded corners */
        }

    input:checked + .slider {
        background-color: black; /* changed to reddish color */
    }

    input:focus + .slider {
        box-shadow: 0 0 1px black; /* changed to reddish color */
    }

    input:checked + .slider:before {
        -webkit-transform: translateX(14px); /* reduced translation */
        -ms-transform: translateX(14px);
        transform: translateX(14px);
    }
</style>
</head>

<div class="card" style="width: 100%; margin: 0 auto; background-color: white;">
    <br />
    <div class="row" style="width: 1300px; margin-left: 618px;">
        <br />
        <h2 align="center"><b>Employee Registration</b></h2>
    </div>
    
    <br />
    <div>
        <form asp-action="create" asp-controller="employee" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row" style="width: 1200px; margin-left: 190px;">
                
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="EmployeeRegister.Name" class="control-label"></label>
                        <input asp-for="EmployeeRegister.Name" class="form-control" style="width:350px;" />
                        <span asp-validation-for="EmployeeRegister.Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="EmployeeRegister.Email" class="control-label"></label>
                        <input asp-for="EmployeeRegister.Email" class="form-control" style="width:350px;" />
                        <span asp-validation-for="EmployeeRegister.Email" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="EmployeeRegister.PhoneNo" class="control-label"></label>
                        <input asp-for="EmployeeRegister.PhoneNo" class="form-control" style="width:350px;" />
                        <span asp-validation-for="EmployeeRegister.PhoneNo" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <br />


            <div class="row" style="width: 1200px; margin-left: 190px;">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="EmployeeRegister.Address" class="control-label"></label>
                        <input asp-for="EmployeeRegister.Address" class="form-control" style="width:350px;" />
                        <span asp-validation-for="EmployeeRegister.Address" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="EmployeeRegister.City" class="control-label"></label>
                        <input asp-for="EmployeeRegister.City" class="form-control" style="width:350px;" />
                        <span asp-validation-for="EmployeeRegister.City" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="EmployeeRegister.State" class="control-label"></label>
                        <input asp-for="EmployeeRegister.State" class="form-control" style="width:350px;" />
                        <span asp-validation-for="EmployeeRegister.State" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <br />


            <div class="row" style="width: 1200px; margin-left: 190px;">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="EmployeeRegister.Hiredate" class="control-label"></label>
                        <input asp-for="EmployeeRegister.Hiredate" class="form-control" style="width:350px;" />
                        <span asp-validation-for="EmployeeRegister.Hiredate" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="EmployeeRegister.Password" class="control-label"></label>
                        <input asp-for="EmployeeRegister.Password" class="form-control" style="width:350px;" />
                        <span asp-validation-for="EmployeeRegister.Password" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4 ">
                    <div class="form-group">
                        <label class="control-label col-sm-3">Gender<span class="alltopcolor pull-right"></span></label>
                        
                        <div class="col-sm-6">
                            <div class="row">
                               
                                    <div class="col-sm-6">
                                        <label class="radio-inline">
                                            @Html.RadioButtonFor(model => model.EmployeeRegister.Gender, "Male", new { @name = "gender", value = "Male", @id = "maleradio" })Male
                                        </label>
                                    </div>
                                    <div class="col-sm-6">
                                        <label class="radio-inline">
                                            @Html.RadioButtonFor(model => model.EmployeeRegister.Gender, "Female", new { @name = "gender", value = "Female", @id = "femaleradio" })Female
                                        </label>
                                    </div>
                                    <div >
                                        @Html.ValidationMessageFor(model => model.EmployeeRegister.Gender, "", new { @class = "error-message" })
                                    </div>
                            </div>
                        </div>
                    </div>
                </div>
                <br />  
                <br />
                <br />
                <br />

                <div class="row" style="width: 1200px; ">

                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="EmployeeRegister.Department" class="control-label" style="margin-left: 10px;"></label>
                            @Html.DropDownListFor(model => model.EmployeeRegister.Department, new SelectList(Model.Department, "Id", "DepartmentName"), "Select Department", new { @class = "form-control", id = "Department", name = "Department", Style = "margin-left: 9px; width: 350px;" })
                        </div>
                        <div class="col-sm-3">
                            @Html.ValidationMessageFor(model => model.EmployeeRegister.Department, "", new { @class = "error-message" })
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="EmployeeRegister.Region" class="control-label" style="margin-left: 10px;"></label>
                            @Html.DropDownListFor(model => model.EmployeeRegister.Region, new SelectList(Model.Region, "Id", "RegionName"), "Select Region", new { @class = "form-control", id = "Region", name = "Region", Style = "margin-left: 9px;  width: 350px;" })
                        </div>
                        <div class="col-sm-3">
                            @Html.ValidationMessageFor(model => model.EmployeeRegister.Region, "", new { @class = "error-message" })
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">

                            <div>
                                <label asp-for="EmployeeRegister.IsActive" class="control-label" style="margin-left: 10px;"></label>
                                <br />
                                <label class="switch" Style="Margin-left:10px;">
                                    <input type="checkbox" checked>
                                    <span class="slider round"></span>
                                </label>
                                
                                <span asp-validation-for="EmployeeRegister.IsActive" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                </div>
                <br />
                <br />
                <br />
                <div class="row" style="width: 1200px; margin-left: 1px;">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="EmployeeRegister.ShiftStartTime" class="control-label"></label>

                            <input asp-for="EmployeeRegister.ShiftStartTime" class="form-control" type="time" min="02:00" max="12:00" value="00:00" style="width:350px;">
                            <span asp-validation-for="EmployeeRegister.ShiftStartTime" class="text-danger"></span>
                        </div>
                    </div>
                   
                  
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="EmployeeRegister.ShiftEndTime" class="control-label"></label>

                            <input asp-for="EmployeeRegister.ShiftEndTime" class="form-control" type="time" min="06:00" max="23:59" value="00:00" style="width:350px;">
                            <span asp-validation-for="EmployeeRegister.ShiftEndTime" class="text-danger"></span>
                        </div>
                    </div>
                   
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="EmployeeRegister.Salary" class="control-label"></label>

                            <input asp-for="EmployeeRegister.Salary" type="number" min="0.00" step="0.01" max="10000000000" value="0" class="form-control" style="width:350px;" />
                            <span asp-validation-for="EmployeeRegister.Salary" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <br />
                <br />
                <br />
               
              

                <div class="row" style="width: 1300px; margin-left: 401px;">
                    
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="EmployeeRegister.Comments " class="control-label"></label>
                            <br />
                            <textarea class="form-control" asp-for="EmployeeRegister.Comments " class="form-control" style="height: 120px; width:350px;"></textarea>
                            @* <input asp-for="EmployeeRegister.Comments " class="form-control" style="height: 120px; width:350px;" /> *@
                            <span asp-validation-for="EmployeeRegister.Comments" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                <div class="row" style="width: 1300px; margin-left: 530px;">
                    <button type="submit" class="btn btn-primary" align="center" style="margin-top:15px; width: 80px;"><i class="fas fa-save"></i> Save</button>
                </div>
                <br />
        </form>
    </div>
    
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}