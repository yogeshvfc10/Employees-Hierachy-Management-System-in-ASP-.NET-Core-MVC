@using DocumentFormat.OpenXml.Office.CustomUI
@model EmployeeHierachy12345.Models.Filter

@{
    ViewData["Title"] = "Index";
}

<head>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" />
</head>

<body>
    
<div class="card">
    <div class="card-header">
        <h1 class="card-title" style="color:dark-black; font-weight: bold;"><b>Employees Board</b></h1>
    </div>

    <div class="card-body">

        <p style="width: 1590px;">
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle-dotted"></i> Add New Employee</a>
            
            <button type="button" id="btnExport" class="btn btn-danger float-right margin-left:25px;" style="margin-left: 12px;">
                <i class="fas fa-file-pdf"></i> PDF
            </button>
            
            <a class="btn btn-success float-right margin-left:25px;" asp-action="ExportPeopleInExcel" style="margin-left:12px; float:right;">
                <i class="fas fa-file-excel"></i> Excel
            </a>
            <button type="button" class="btn btn-info float-right" data-toggle="modal" data-target="#FilterModal" align="center" >
                <i class="fas fa-filter"></i> Filter
            </button>
        </p>
        
        <!-- Filter Record-->
        <div class="modal fade" id="FilterModal" tabindex="-1" role="dialog" aria-labelledby="exampleModelLabel">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <form asp-action="Filter" asp-controller="Employee" method="post">
                        <div class="modal-header">
                            <h3 class="modal-title" id="exampleModalLabel"><b>Filter</b></h3>
                            <button type="button" class="close" data-dismiss="modal" aria-label="close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>

                        <div class="modal-body">
                            <div class="form-group">
                                <label asp-for="EmployeeRegister.Name" class="control-label"></label>
                                <input asp-for="EmployeeRegister.Name" class="form-control" />
                                <span asp-validation-for="EmployeeRegister.Name" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="EmployeeRegister.Department" class="control-label"></label>
                                @Html.DropDownListFor(Model => Model.EmployeeRegister.Department, new SelectList(Model.Departments, "Id", "DepartmentName"), "Select Department", new { @class = "form-control", id = "Department", name = "Department" })
                                <span asp-validation-for="EmployeeRegister.Department" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="EmployeeRegister.Region" class="control-label"></label>
                                @Html.DropDownListFor(Model => Model.EmployeeRegister.Region, new SelectList(Model.Regions, "Id", "RegionName"), "Select Region", new { @class = "form-control", id = "Region", name = "Region" })
                                <span asp-validation-for="EmployeeRegister.Region" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="modal-footer">
                            <button asp-action="ClearFilter" asp-controller="Employee" class="btn btn-primary btncancel">Clear All</button>
                            <button type="submit" class="btn btn-primary">Filter</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>

        <!--Table-->
        
        <table id="example1" class="table table-bordered table-striped">
            <thead class="thead-dark">
                <tr>
                    @* <th>
                    @Html.DisplayNameFor(model => model.Id)
                    </th> *@
                    <th>
                        @Html.DisplayNameFor(model => model.Name)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Email)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.PhoneNo)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Address)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.City)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.State)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Hiredate)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Gender)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Region)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Department)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ShiftStartTime)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ShiftEndTime)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Salary)
                    </th>
                    @* <th>
                    @Html.DisplayNameFor(model => model.IsActive)
                    </th> *@
                    <th>
                        @Html.DisplayNameFor(model => model.Comments)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Timespan)
                    </th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.GeneralModel)
                {
                    <tr>
                       
                        <td>
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Email)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.PhoneNo)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Address)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.City)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.State)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Hiredate)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Gender)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Region)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Department)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ShiftStartTime)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ShiftEndTime)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Salary)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Comments)
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.Timespan)
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary"><i class="fa fa-pencil"></i>Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-secondary"><i class="fa fa-eye"></i>View</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger"><i class="fa fa-trash"></i>Delete</a>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
</body>

<!--- PDF --->

<script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/1.8.3/jquery.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.22/pdfmake.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/0.4.1/html2canvas.min.js"></script>
<script type="text/javascript">
    $("body").on("click", "#btnExport", function () {
        html2canvas($('[id*=example1]')[0], {
            onrendered: function (canvas) {
                var data = canvas.toDataURL();
                var docDefinition = {
                    content: [{
                        image: data,
                        width: 500
                    }]
                };
                pdfMake.createPdf(docDefinition).download("Table1.pdf");
            }
        });
    });
</script>



